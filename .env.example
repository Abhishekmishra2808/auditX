# Financial Mapper Configuration
# Copy this file to .env and fill in your actual values

# =====================================================================
# Hugging Face LLM Configuration
# =====================================================================

# Your Hugging Face API key (get from https://huggingface.co/settings/tokens)
HF_API_KEY=your_hf_api_key_here

# Hugging Face model to use for label mapping
# Current: mistralai/Mistral-7B-Instruct-v0.2
# Alternatives:
#   - mistralai/Mistral-7B-Instruct-v0.3
#   - meta-llama/Llama-2-7b-chat-hf
# See HF_API_DIAGNOSTIC.md if you get 410 errors
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# HTTP timeout for HF API calls (seconds)
HF_TIMEOUT=20

# Minimum confidence (0.0-1.0) for LLM mappings to be accepted
# Lower = more lenient (risk of wrong mappings)
# Higher = more conservative (more unmapped labels)
# Recommended: 0.75
LLM_CONFIDENCE_THRESHOLD=0.75

# Enable/disable LLM fallback layer
# Set to false to disable LLM and use only deterministic matching
HF_ENABLED=true

# =====================================================================
# Application Configuration
# =====================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Path to custom synonyms JSON file (optional)
# If set, these synonyms will be loaded and merged with built-ins
CUSTOM_SYNONYM_PATH=financial_mapper/data/custom_synonyms.json

# Path to save user-confirmed mappings for future runs
USER_CONFIRMED_MAPPINGS=financial_mapper/data/user_mappings.json

# =====================================================================
# Flask Web Server (if using web UI)
# =====================================================================

FLASK_DEBUG=false
FLASK_ENV=production
